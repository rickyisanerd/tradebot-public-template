# ── Broker Mode ─────────────────────────────────────────────
# demo | paper | live
BROKER_MODE=demo
ALPACA_KEY_ID=your_alpaca_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_here

# ── Auto Trading ───────────────────────────────────────────
AUTO_TRADE_ENABLED=true
AUTO_TRADE_INTERVAL_MINUTES=30
PDT_COOLDOWN_HOURS=20
REBUY_COOLDOWN_HOURS=48
REBUY_AFTER_SELL_COOLDOWN_HOURS=4

# ── Position Sizing & Risk ─────────────────────────────────
# These values act as the floor. The bot scales them upward as equity grows.
# STARTING_CASH is the demo baseline for that scaling; it does not change live.
MAX_TOTAL_CAPITAL=500
MAX_OPEN_POSITIONS=5
MAX_NEW_POSITIONS_PER_RUN=3
RISK_PER_TRADE_PCT=0.04
MAX_POSITION_PCT=0.25
# Inverse ETFs hedge a falling market, but every fund shorting the same index
# is one bet. Limits below cap distinct inverse positions and their combined
# share of equity (0 = unlimited; same-index stacking is always blocked).
MAX_INVERSE_POSITIONS=2
MAX_INVERSE_EXPOSURE_PCT=0.30
# Hours the regime filter must stay weak before inverse hedges may be bought
# (0 = hedge on the first weak reading). Prefer 1x funds (SH,PSQ,DOG) over 3x:
# tight stops on leveraged products stop out on ordinary index noise.
INVERSE_CONFIRMATION_HOURS=18
# Skip buys when a tracked earnings report is this close (0 = off; requires
# the earnings signal / ALPHA_VANTAGE_API_KEY to have data).
EARNINGS_BLACKOUT_DAYS=2
MIN_REWARD_RISK=1.2
DRAWDOWN_SOFT_LIMIT_PCT=0.10
DRAWDOWN_HARD_LIMIT_PCT=0.20
DAILY_LOSS_LIMIT_PCT=0.05
DAILY_LOSS_LIMIT_DOLLARS=0
LIQUIDATE_ON_DAILY_LOSS=false
PROFIT_LOCK_DOLLARS=0
MAX_CONSECUTIVE_BUY_ERRORS=3
# Skip buy orders below this dollar amount (Alpaca rejects fractional orders under $1).
MIN_BUY_NOTIONAL=1.25
PAUSE_NEW_BUYS_ON_DEGRADED_SIGNALS=true
BUY_KILL_SWITCH=false
# Accepts either 8 or 0.08 for an 8% stop.
STOP_LOSS_PCT=0.08
USE_BROKER_PROTECTIVE_ORDERS=true
PROTECTIVE_STOP_REPLACE_MIN_STEP_PCT=0.01
MIN_HOLD_DAYS=1
MAX_HOLD_DAYS=10

# ── Universe Scanning ──────────────────────────────────────
MAX_STOCK_PRICE=10
# Set MAX_STOCK_PRICE=0 to remove the upper price cap.
MIN_STOCK_PRICE=2
# Exclude broad-market / index / sector ETFs (SPY, VTI, QQQ, XLK, sector SPDRs,
# ...) from buy candidates: the bot has no single-name edge there, it just buys
# beta at full price (often the local top). Set false to allow them; override
# the list with BROAD_MARKET_ETFS=SYM1,SYM2,...
EXCLUDE_BROAD_MARKET_ETFS=true
SCAN_LIMIT=200
CANDIDATE_LIMIT=30
MIN_DOLLAR_VOLUME=1000000
LOOKBACK_DAYS=80
LIVE_UNIVERSE_MODE=liquid
MARKET_REGIME_FILTER=false
MARKET_REGIME_SYMBOLS=SPY,QQQ
MARKET_REGIME_SHORT_WINDOW=20
MARKET_REGIME_LONG_WINDOW=50
MARKET_REGIME_BLOCK_ON_MISSING=true
MARKET_REGIME_ALLOW_LIMITED_LONGS=true
MARKET_REGIME_LIMITED_LONG_MIN_SCORE=75
MARKET_REGIME_LIMITED_LONG_MAX_POSITION_PCT=0.18
MARKET_REGIME_LIMITED_LONG_RISK_PCT=0.025
INVERSE_CONFIRMATION_HOURS=4
SHADOW_MODE_STRATEGIES=false
SHADOW_MIN_SCORE=50
SHADOW_MAX_PICKS_PER_CYCLE=5
SHADOW_REVIEW_DAYS=5
WEEKLY_REPORT_DAYS=7
# Optional comma-separated override (leave blank to scan full market)
# SCAN_UNIVERSE=SOFI,PLUG,RIVN,LCID,NOK
# Optional comma-separated override for live/paper liquid universe mode.
# LIQUID_SCAN_UNIVERSE=SPY,QQQ,AAPL,MSFT,NVDA,AMZN,GOOGL,META,TSLA

# ── Congress Signals ───────────────────────────────────────
# New filings are discovered automatically from the official House Clerk and
# Senate eFD disclosure feeds (the same sources Capitol Trades ingests).
CONGRESS_AUTO_FETCH=true
CONGRESS_INCLUDE_SENATE=true
CONGRESS_LOOKBACK_DAYS=30
CONGRESS_MAX_REPORTS=50
# Set to 0 to keep congressional trades at any share price.
CONGRESS_MAX_PRICE=10
CONGRESS_TRADE_LIMIT=20
CONGRESS_SIGNAL_WINDOW_DAYS=45
CONGRESS_FRESHNESS_HOURS=24
CONGRESS_MIN_RECORDS=1
CONGRESS_RETRY_MINUTES=15
CONGRESS_OVERRIDE_MODE=auto
DECISION_SUPPORT_CONGRESS_WEIGHT=1.0
# Optional comma-separated list of extra official PTR PDF URLs to parse
# in addition to the auto-discovered filings.
# CONGRESS_REPORT_URLS=https://disclosures-clerk.house.gov/public_disc/ptr-pdfs/2026/20033918.pdf

# ── SEC Signals ────────────────────────────────────────────
SEC_USER_AGENT=
SEC_SIGNAL_WINDOW_DAYS=30
SEC_FILING_LIMIT_PER_SYMBOL=20
SEC_FRESHNESS_HOURS=24
SEC_MIN_RECORDS=1
SEC_RETRY_MINUTES=15
SEC_OVERRIDE_MODE=auto
DECISION_SUPPORT_SEC_WEIGHT=1.0

# ── Earnings Signals ──────────────────────────────────────
ALPHA_VANTAGE_API_KEY=
# Checks https://finance.yahoo.com/quote/{ticker} first, then StockAnalysis as fallback.
ANALYST_CONSENSUS_ENABLED=true
ANALYST_CONSENSUS_BLOCK_HOLD=true
ANALYST_CONSENSUS_MIN_UPSIDE_PCT=0
ANALYST_CONSENSUS_CACHE_HOURS=24
# Skip ETF-style symbols whose analyst pages are noisy or unavailable.
ANALYST_CONSENSUS_SKIP_SYMBOLS=SPY,QQQ,IWM,DIA,VTI,VOO,XLK,XLF,XLE,XLV,XLY,XLI,ARKK,SOXS,LABU,SPXS,SQQQ,SDOW,SH,PSQ,DOG,SPXU,TECS
EARNINGS_SIGNAL_WINDOW_DAYS=21
EARNINGS_FRESHNESS_HOURS=24
EARNINGS_MIN_RECORDS=1
EARNINGS_RETRY_MINUTES=15
EARNINGS_OVERRIDE_MODE=auto
DECISION_SUPPORT_EARNINGS_WEIGHT=1.0

# ── Macro Signals ─────────────────────────────────────────
MACRO_SIGNAL_WINDOW_DAYS=7
MACRO_FRESHNESS_HOURS=24
MACRO_MIN_RECORDS=1
MACRO_RETRY_MINUTES=15
MACRO_OVERRIDE_MODE=auto
DECISION_SUPPORT_MACRO_WEIGHT=1.0

# ── Demo Mode ─────────────────────────────────────────────
STARTING_CASH=500
DEMO_SEED=42

# ── Dashboard ─────────────────────────────────────────────
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8008
ANALYZER_MODE=embedded

# E*TRADE Mirror (optional follower account)
ETRADE_MIRROR_ENABLED=false
ETRADE_MIRROR_ENV=sandbox
ETRADE_ACCOUNT_ID_KEY=
ETRADE_MIRROR_PREVIEW_ONLY=true
ETRADE_MIRROR_MAX_ORDER_VALUE=250
ETRADE_MIRROR_MAX_TOTAL_CAPITAL=500
ETRADE_SANDBOX_CONSUMER_KEY=
ETRADE_SANDBOX_CONSUMER_SECRET=
ETRADE_SANDBOX_ACCESS_TOKEN=
ETRADE_SANDBOX_ACCESS_TOKEN_SECRET=
ETRADE_LIVE_CONSUMER_KEY=
ETRADE_LIVE_CONSUMER_SECRET=
ETRADE_LIVE_ACCESS_TOKEN=
ETRADE_LIVE_ACCESS_TOKEN_SECRET=
ETRADE_OAUTH_CALLBACK=oob

# ── Daily Email Report (optional, via Resend) ─────────────
# Leave RESEND_API_KEY / REPORT_EMAIL blank to disable emails entirely.
RESEND_API_KEY=
REPORT_EMAIL=you@example.com
REPORT_SENDER_EMAIL=TradeBot <reports@example.com>
# Link shown in the email footer (your deployed dashboard URL).
REPORT_DASHBOARD_URL=http://127.0.0.1:8008/

# ── Railway Deployment ────────────────────────────────────
# Railway injects PORT automatically, and the app respects that.
# If you mount a Railway volume, point DATA_DIR at it so SQLite persists.
# DATA_DIR=/data

# ── Presets ───────────────────────────────────────────────
#
# Small Account Aggressive ($500 start):
#   BROKER_MODE=paper
#   MAX_STOCK_PRICE=10
#   MIN_STOCK_PRICE=1
#   MAX_TOTAL_CAPITAL=500
#   MAX_OPEN_POSITIONS=5
#   MAX_NEW_POSITIONS_PER_RUN=3
#   RISK_PER_TRADE_PCT=0.04
#   MAX_POSITION_PCT=0.25
#   MIN_REWARD_RISK=1.2
#   STOP_LOSS_PCT=0.08
#   MIN_HOLD_DAYS=1
#   MAX_HOLD_DAYS=10
#   AUTO_TRADE_ENABLED=true
#   AUTO_TRADE_INTERVAL_MINUTES=30
#   USE_BROKER_PROTECTIVE_ORDERS=true
#
# Cautious Railway Paper:
#   BROKER_MODE=paper
#   ALPACA_KEY_ID=your_paper_key
#   ALPACA_SECRET_KEY=your_paper_secret
#   DATA_DIR=/data
#   AUTO_TRADE_ENABLED=false
#   MAX_TOTAL_CAPITAL=1000
#   MAX_OPEN_POSITIONS=1
#   MAX_NEW_POSITIONS_PER_RUN=1
#   MAX_POSITION_PCT=0.10
#   RISK_PER_TRADE_PCT=0.005
#   STOP_LOSS_PCT=0.05
#   USE_BROKER_PROTECTIVE_ORDERS=true
#   MIN_HOLD_DAYS=1
#   MAX_HOLD_DAYS=5
#   SEC_USER_AGENT=TradeBot your-email@example.com
#   ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
#
# Cautious Railway Live:
#   BROKER_MODE=live
#   ALPACA_KEY_ID=your_live_key
#   ALPACA_SECRET_KEY=your_live_secret
#   DATA_DIR=/data
#   AUTO_TRADE_ENABLED=false
#   MAX_TOTAL_CAPITAL=1000
#   MAX_OPEN_POSITIONS=1
#   MAX_NEW_POSITIONS_PER_RUN=1
#   MAX_POSITION_PCT=0.10
#   RISK_PER_TRADE_PCT=0.005
#   STOP_LOSS_PCT=0.05
#   USE_BROKER_PROTECTIVE_ORDERS=true
#   MIN_HOLD_DAYS=1
#   MAX_HOLD_DAYS=5
#   SEC_USER_AGENT=TradeBot your-email@example.com
#   ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
