# Broker mode
# demo | paper | live
BROKER_MODE=demo
ALPACA_KEY_ID=your_alpaca_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_here

# Auto trading
AUTO_TRADE_ENABLED=true
AUTO_TRADE_INTERVAL_MINUTES=30
PDT_COOLDOWN_HOURS=20
REBUY_COOLDOWN_HOURS=48

# Position sizing and risk
# These values act as the floor. The bot scales them upward as equity grows.
# STARTING_CASH is the demo baseline for that scaling; it does not change live.
MAX_TOTAL_CAPITAL=500
MAX_OPEN_POSITIONS=5
MAX_NEW_POSITIONS_PER_RUN=3
RISK_PER_TRADE_PCT=0.04
MAX_POSITION_PCT=0.25
MIN_REWARD_RISK=1.2
DRAWDOWN_SOFT_LIMIT_PCT=0.10
DRAWDOWN_HARD_LIMIT_PCT=0.20
DAILY_LOSS_LIMIT_PCT=0.05
MAX_CONSECUTIVE_BUY_ERRORS=3
PAUSE_NEW_BUYS_ON_DEGRADED_SIGNALS=true
BUY_KILL_SWITCH=false
STOP_LOSS_PCT=0.08
TRAILING_STOP_PCT=0.10
USE_BROKER_PROTECTIVE_ORDERS=true
MIN_HOLD_DAYS=1
MAX_HOLD_DAYS=10
PARTIAL_PROFIT_ENABLED=true
PARTIAL_PROFIT_PCT=15
PARTIAL_SELL_FRACTION=0.5

# Universe scanning
MAX_STOCK_PRICE=10
MIN_STOCK_PRICE=2
SCAN_LIMIT=200
CANDIDATE_LIMIT=30
MIN_DOLLAR_VOLUME=1000000
LOOKBACK_DAYS=80
# Optional comma-separated override
# SCAN_UNIVERSE=SOFI,PLUG,RIVN,LCID,NOK

# Congress signals
CONGRESS_MAX_PRICE=10
CONGRESS_TRADE_LIMIT=20
CONGRESS_SIGNAL_WINDOW_DAYS=45
CONGRESS_FRESHNESS_HOURS=24
CONGRESS_MIN_RECORDS=1
CONGRESS_RETRY_MINUTES=15
CONGRESS_OVERRIDE_MODE=auto
DECISION_SUPPORT_CONGRESS_WEIGHT=1.0
# Optional comma-separated list of official House or Senate PTR PDF URLs.
# CONGRESS_REPORT_URLS=https://disclosures-clerk.house.gov/public_disc/ptr-pdfs/2026/example.pdf

# SEC signals
SEC_USER_AGENT=TradeBot your-email@example.com
SEC_SIGNAL_WINDOW_DAYS=30
SEC_FILING_LIMIT_PER_SYMBOL=20
SEC_FRESHNESS_HOURS=24
SEC_MIN_RECORDS=1
SEC_RETRY_MINUTES=15
SEC_OVERRIDE_MODE=auto
DECISION_SUPPORT_SEC_WEIGHT=1.0

# Earnings signals
ALPHA_VANTAGE_API_KEY=
EARNINGS_SIGNAL_WINDOW_DAYS=21
EARNINGS_FRESHNESS_HOURS=24
EARNINGS_MIN_RECORDS=1
EARNINGS_RETRY_MINUTES=15
EARNINGS_OVERRIDE_MODE=auto
DECISION_SUPPORT_EARNINGS_WEIGHT=1.0

# Macro signals
MACRO_SIGNAL_WINDOW_DAYS=7
MACRO_FRESHNESS_HOURS=24
MACRO_MIN_RECORDS=1
MACRO_RETRY_MINUTES=15
MACRO_OVERRIDE_MODE=auto
DECISION_SUPPORT_MACRO_WEIGHT=1.0

# Short volume
POLYGON_API_KEY=
SHORT_VOLUME_SIGNAL_ENABLED=true
DECISION_SUPPORT_SHORT_VOLUME_WEIGHT=1.0

# Inverse ETF hedging
INVERSE_ETFS_ENABLED=true
INVERSE_ETFS=SPXS,SQQQ,SDOW,SH,PSQ,DOG,SPXU,TECS

# Demo mode
STARTING_CASH=500
DEMO_SEED=42

# Dashboard
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8008
ANALYZER_MODE=embedded

# Email reports
RESEND_API_KEY=
REPORT_EMAIL=your-email@example.com
REPORT_SENDER_EMAIL=TradeBot <reports@example.com>
REPORT_DASHBOARD_URL=http://127.0.0.1:8008/

# Deployment notes
# Railway injects PORT automatically, and the app respects that.
# If you mount a persistent volume, point DATA_DIR at it so SQLite persists.
# DATA_DIR=/data
